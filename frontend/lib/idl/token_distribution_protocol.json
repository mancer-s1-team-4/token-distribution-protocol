        {
          "name": "creator",
          "docs": [
            "Only the stream creator may append milestones."
          ],
          "writable": true,
          "signer": true,
          "relations": [
            "stream_data"
          ]
        },
        {
          "name": "recipient"
        },
        {
          "name": "stream_data",
          "docs": [
            "The vesting schedule PDA.",
            "Constraints:",
            "has_one = creator        → Unauthorized",
            "stream_type == Milestone → InvalidStreamType",
            "!is_cancelled            → StreamExpired",
            "milestones.len() < MAX   → TooManyMilestones"
          ],
          "writable": true,
          "pda": {
