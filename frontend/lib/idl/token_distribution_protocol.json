      "name": "add_milestone",
      "docs": [
        "Appends a milestone entry to a Milestone-type stream. Called by the",
        "creator after create_stream to configure each performance gate before",
        "recipient activity begins."
      ],
      "discriminator": [
        165,
        18,
        177,
        128,
        204,
        172,
        23,
        249
      ],
